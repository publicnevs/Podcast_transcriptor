# ── Gemini ────────────────────────────────────────────────────────────────
# API Key — https://aistudio.google.com/apikey
# Kann auch später in der App unter Einstellungen gesetzt werden.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Transkriptions-Backend ──────────────────────────────────────────────────
# "gemini" (Cloud, empfohlen) oder "whisper" (lokal, langsam auf DS218+)
TRANSCRIPTION_BACKEND=gemini

# Nur für Whisper: tiny | base | small  (base empfohlen für DS218+)
WHISPER_MODEL=base
# WHISPER_THREADS=2          # optional: CPU-Threads (0 = alle)

# ── Pfade (Defaults passen für Docker) ──────────────────────────────────────
DB_PATH=/app/data/podscribe.db
DOWNLOAD_DIR=/app/downloads
