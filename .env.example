# ── Gemini ────────────────────────────────────────────────────────────────
# API Key — https://aistudio.google.com/apikey
# Kann auch später in der App unter Einstellungen gesetzt werden.
GEMINI_API_KEY=your_gemini_api_key_here

# Modelle (Defaults sind sinnvoll). Das Lite-Modell für Anreicherung + Tagging
# spart Kosten (~3–5× günstiger als Flash). Ohne diese Variable nutzt "Lite"
# automatisch Flash — es wird dann NICHT gespart. Daher empfohlen zu setzen:
GEMINI_LITE_MODEL=gemini-2.5-flash-lite
# GEMINI_FLASH_MODEL=gemini-2.5-flash    # Transkription
# GEMINI_PRO_MODEL=gemini-2.5-pro        # Zeitung/Artikel (beste Qualität)
# GEMINI_DIGEST_MODEL=gemini-2.5-pro     # Artikel-Modell; in Settings Pro/Flash umschaltbar

# ── Transkriptions-Backend ──────────────────────────────────────────────────
# "gemini" (Cloud, empfohlen) oder "whisper" (lokal, langsam auf DS218+)
TRANSCRIPTION_BACKEND=gemini

# Nur für Whisper: tiny | base | small  (base empfohlen für DS218+)
WHISPER_MODEL=base
# WHISPER_THREADS=2          # optional: CPU-Threads (0 = alle)

# ── Pfade (Defaults passen für Docker) ──────────────────────────────────────
DB_PATH=/app/data/podscribe.db
DOWNLOAD_DIR=/app/downloads
